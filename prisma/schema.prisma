generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Fund {
  id                   String   @id @default(cuid())
  name                 String
  description          String?
  organizerAddress     String
  fundWalletAddress    String   @unique
  fundWalletSeed       String
  quorumRequired       Int
  minContribution      Int
  requestCapMultiplier Float    @default(2.0)
  maxPoolPercent       Float    @default(0.2)
  inviteCode           String   @unique
  createdAt            DateTime @default(now())

  members  Member[]
  requests Request[]

  @@index([organizerAddress])
}

model Member {
  id               String    @id @default(cuid())
  fundId           String
  fund             Fund      @relation(fields: [fundId], references: [id])
  walletAddress    String
  signerAddress    String
  displayName      String
  totalContributed Int       @default(0)
  lastContribution DateTime?
  status           String    @default("active")
  nftTokenId       String?
  joinedAt         DateTime  @default(now())

  contributions Contribution[]

  @@unique([fundId, walletAddress])
  @@index([walletAddress])
  @@index([fundId])
}

model Contribution {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  amount    Int
  txHash    String   @unique
  createdAt DateTime @default(now())

  @@index([memberId])
}

model Request {
  id                  String    @id @default(cuid())
  fundId              String
  fund                Fund      @relation(fields: [fundId], references: [id])
  requesterAddress    String
  amount              Int
  description         String
  documentHash        String
  escrowSequence      Int?
  escrowCondition     String?
  escrowFulfillment   String?
  status              String    @default("submitted")
  expiresAt           DateTime?
  createdAt           DateTime  @default(now())

  votes Vote[]

  @@index([fundId])
  @@index([fundId, status])
  @@index([requesterAddress])
}

model Vote {
  id           String   @id @default(cuid())
  requestId    String
  request      Request  @relation(fields: [requestId], references: [id])
  voterAddress String
  signature    String
  createdAt    DateTime @default(now())

  @@unique([requestId, voterAddress])
  @@index([requestId])
}
