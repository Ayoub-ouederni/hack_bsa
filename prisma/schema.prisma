generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Fund {
  id                   String   @id @default(cuid())
  name                 String
  description          String?
  organizerAddress     String
  fundWalletAddress    String   @unique
  fundWalletSeed       String
  quorumRequired       Int
  minContribution      Int
  requestCapMultiplier Float    @default(2.0)
  maxPoolPercent       Float    @default(0.2)
  inviteCode           String   @unique
  createdAt            DateTime @default(now())
}

model Member {
  id               String    @id @default(cuid())
  fundId           String
  walletAddress    String
  signerAddress    String
  displayName      String
  totalContributed Int       @default(0)
  lastContribution DateTime?
  status           String    @default("active")
  nftTokenId       String?
  joinedAt         DateTime  @default(now())

  @@unique([fundId, walletAddress])
}

model Contribution {
  id        String   @id @default(cuid())
  memberId  String
  amount    Int
  txHash    String   @unique
  createdAt DateTime @default(now())
}

model Request {
  id                  String    @id @default(cuid())
  fundId              String
  requesterAddress    String
  amount              Int
  description         String
  documentHash        String
  escrowSequence      Int?
  escrowCondition     String?
  escrowFulfillment   String?
  status              String    @default("submitted")
  expiresAt           DateTime?
  createdAt           DateTime  @default(now())
}
